[
  {
    "id": "love_mature_first",
    "version": "1.0.0",
    "category": "side_quest",
    "priority": 1,
    "weight": 45,
    "ageRange": { "min": 30, "max": 45 },
    "triggers": [
      {"type": "age_reach", "value": 30},
      {"type": "random", "value": 0.15}
    ],
    "conditions": [
      {"type": "expression", "expression": "!flags.has(\"love_started\") && !flags.has(\"love_mature_started\")"}
    ],
    "content": {
      "text": "多年行走江湖，你已褪去年少轻狂，多了几分沉稳。一次偶然的机会，你遇到了一位同样成熟的江湖人士，彼此心生好感。",
      "title": "成熟之恋",
      "description": "岁月沉淀后的爱情更加醇厚。"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "love_mature_accept",
        "text": "接受这份感情",
        "effects": [
          {"type": "flag_set", "target": "love_mature_started"},
          {"type": "flag_set", "target": "love_started"},
          {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mature", "name": "婉清", "role": "lover", "delta": 15}},
          {"type": "stat_modify", "target": "charisma", "value": 5, "operator": "add"},
          {"type": "stat_modify", "target": "chivalry", "value": 3, "operator": "add"},
          {"type": "event_record", "target": "love_mature_accept"}
        ]
      },
      {
        "id": "love_mature_decline",
        "text": "婉拒，专心武道",
        "effects": [
          {"type": "time_advance", "target": "age", "value": 1, "timeUnit": "month"},
          {"type": "stat_modify", "target": "martialPower", "value": 3, "operator": "add"},
          {"type": "event_record", "target": "love_mature_decline"}
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773450500000,
      "updatedAt": 1773450500000,
      "author": "development_team",
      "tags": ["爱情", "成熟", "中年", "支线"],
      "enabled": true
    }
  },
  {
    "id": "love_mature_bond",
    "version": "1.0.0",
    "category": "side_quest",
    "priority": 1,
    "weight": 40,
    "ageRange": {"min": 31, "max": 50},

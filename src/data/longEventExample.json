    {
      "id": "seek_manual_event",
      "name": "寻找秘籍事件",
      "stages": [
        {
          "node": {
            "id": "seek_manual_start",
            "minAge": 16,
            "maxAge": 35,
            "text": "你听说在东海之滨有一本上古秘籍，决定去寻找。",
            "condition": {
              "op": "and",
              "conditions": [
                { "op": "gte", "field": "qinggong", "value": 15 },
                { "op": "not", "condition": { "op": "hasEvent", "field": "events", "value": "seekManual" } }
              ]
            },
            "weight": 10,
            "choices": [
              {
                "id": "seek_1_week",
                "text": "寻找 1 周",
                "timeSpan": { "value": 7, "unit": "day" },
                "effects": [
                  { "op": "random", "field": "martialPower", "minValue": 0, "maxValue": 5 },
                  { "op": "addEvent", "field": "events", "value": "seekManual" }
                ]
              },
              {
                "id": "seek_1_month",
                "text": "寻找 1 个月",
                "timeSpan": { "value": 30, "unit": "day" },
                "effects": [
                  { "op": "random", "field": "martialPower", "minValue": 5, "maxValue": 15 },
                  { "op": "add", "field": "qinggong", "value": 5 },
                  { "op": "addEvent", "field": "events", "value": "seekManual" }
                ]
              },
              {
                "id": "seek_3_months",
                "text": "寻找 3 个月",
                "timeSpan": { "value": 90, "unit": "day" },
                "effects": [
                  { "op": "random", "field": "martialPower", "minValue": 15, "maxValue": 30 },
                  { "op": "add", "field": "qinggong", "value": 10 },
                  { "op": "addFlag", "field": "flags", "value": "foundManual" },
                  { "op": "addEvent", "field": "events", "value": "seekManual" }
                ]
              }
            ]
          }
        },
        {
          "node": {
            "id": "seek_manual_found",
            "minAge": 16,
            "maxAge": 36,
            "text": "功夫不负有心人！你在一处海蚀洞中找到了那本上古秘籍！",
            "condition": {
              "op": "hasFlag",
              "field": "flags",
              "value": "foundManual"
            },
            "autoNext": true,
            "weight": 100,
            "timeSpan": { "value": 1, "unit": "day" },
            "autoEffects": [
              { "op": "add", "field": "internalSkill", "value": 50 },

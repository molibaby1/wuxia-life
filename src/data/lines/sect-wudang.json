  {
    "id": "orthodox_trial_entry",
    "version": "1.0.0",
    "category": "main_story",
    "priority": 1,
    "weight": 70,
    "ageRange": {
      "min": 13,
      "max": 17
    },
    "triggers": [
      { "type": "age_reach", "value": 13 }
    ],
    "conditions": [
      {
        "type": "expression",
        "expression": "flags.has(\"orthodox_trial_active\") && !flags.has(\"orthodox_trial_started\")"
      }
    ],
    "content": {
      "text": "正道入门试炼开启，长老要求你先修心性，再修内劲，最后以仁义解危。",
      "title": "正道试炼",
      "description": "心性与武艺并重。"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "orthodox_trial_mind",
        "text": "修心：诵经静坐",
        "weight": 3,
        "effects": [
          { "type": "flag_set", "target": "orthodox_trial_started" },
          { "type": "time_advance", "target": "age", "value": 10, "timeUnit": "day" },
          { "type": "stat_modify", "target": "chivalry", "value": 2, "operator": "add" },
          { "type": "flag_set", "target": "orthodox_trial_mind_done" },
          { "type": "event_record", "target": "orthodox_trial_mind" }
        ]
      },
      {
        "id": "orthodox_trial_mind_delay",
        "text": "修心：迟疑不决，延期复修",
        "weight": 1,
        "effects": [
          { "type": "flag_set", "target": "orthodox_trial_started" },
          { "type": "time_advance", "target": "age", "value": 14, "timeUnit": "day" },
          { "type": "stat_modify", "target": "chivalry", "value": 1, "operator": "add" },
          { "type": "flag_set", "target": "orthodox_trial_mind_delayed" },
          { "type": "event_record", "target": "orthodox_trial_mind_delay" }
        ]
      },
      {
        "id": "orthodox_trial_force",
        "text": "修劲：内力循环",
        "weight": 3,
        "effects": [
          { "type": "flag_set", "target": "orthodox_trial_started" },
          { "type": "time_advance", "target": "age", "value": 12, "timeUnit": "day" },
          { "type": "stat_modify", "target": "internalSkill", "value": 3, "operator": "add" },
          { "type": "flag_set", "target": "orthodox_trial_force_done" },
          { "type": "event_record", "target": "orthodox_trial_force" }
        ]
      },
      {
        "id": "orthodox_trial_force_fail",
        "text": "修劲：真气逆行受伤",
        "weight": 1,
        "effects": [
          { "type": "flag_set", "target": "orthodox_trial_started" },
          { "type": "time_advance", "target": "age", "value": 8, "timeUnit": "day" },
          { "type": "stat_modify", "target": "health", "value": 8, "operator": "subtract" },
          { "type": "flag_set", "target": "orthodox_trial_force_failed" },
          { "type": "event_record", "target": "orthodox_trial_force_fail" }
        ]
      }
    ],

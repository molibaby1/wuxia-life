    "content": {
      "title": "门主密令",
      "text": "门主给你下达任务：'有一个正道门派与我派有旧怨，你需要前往调查。记住，我们不主动惹事，但也不怕事。'"
    },
    "choices": [
      {
        "id": "complete_mission",
        "text": "坚决执行任务 (武力 +15, 声望 -10)",
        "effects": [
          {"type": "stat_modify", "target": "martialPower", "value": 15, "operator": "add"},
          {"type": "stat_modify", "target": "reputation", "value": -10, "operator": "add"}
        ]
      },
      {
        "id": "question_mission",
        "text": "询问任务详情，保留判断 (悟性 +5)",
        "effects": [
          {"type": "stat_modify", "target": "comprehension", "value": 5, "operator": "add"}
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773317774544,

      {
        "id": "love_elderly_friend",
        "text": "做一对知己好友",
        "effects": [
          {"type": "flag_set", "target": "love_elderly_friend"},
          {"type": "stat_modify", "target": "charisma", "value": 5, "operator": "add"},
          {"type": "stat_modify", "target": "health", "value": 10, "operator": "add"},
          {"type": "event_record", "target": "love_elderly_friend"}
        ]
      }

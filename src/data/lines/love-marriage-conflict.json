          {"type": "stat_modify", "stat": "chivalry", "value": 10},
          {"type": "stat_modify", "stat": "connections", "value": -10},
          {"type": "flag_set", "flag": "mingyue_fiancee", "value": true}
        ]
      },
      {
        "text": "接受联姻，放弃明月",
        "effects": [
          {"type": "flag_set", "flag": "marriage_arranged", "value": true},
          {"type": "flag_set", "flag": "spouse_rich_merchant", "value": true},
          {"type": "stat_modify", "stat": "money", "value": 300},
          {"type": "stat_modify", "stat": "connections", "value": 30},
          {"type": "stat_modify", "stat": "chivalry", "value": -20},
          {"type": "flag_set", "flag": "mingyue_married_other", "value": true}
        ]
      },
      {
        "text": "拖延不决，两边敷衍",
        "effects": [
          {"type": "flag_set", "flag": "love_hesitant", "value": true},
          {"type": "stat_modify", "stat": "charisma", "value": -5},
          {"type": "stat_modify", "stat": "reputation", "value": -5}
        ]
      }
    ],
    "metadata": {
      "pathAffinity": {
        "martial_artist": 20,
        "merchant": 30
      },
      "pathConflicts": {
        "hermit": 40
      },
      "tags": ["爱情", "婚姻", "冲突", "抉择"]

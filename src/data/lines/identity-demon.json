    "content": {
      "title": "独特武学",
      "text": "教主赐予你幽影门秘籍：'此功威力惊人，但与传统武学理念不同。你可愿意修炼？记住：力量本身无善恶，关键在如何使用。'"
    },
    "choices": [
      {
        "id": "cultivate_aggressive",
        "text": "全力修炼，追求力量 (武力 +20)",
        "effects": [
          {"type": "stat_modify", "target": "martialPower", "value": 20, "operator": "add"}
        ]
      },
      {
        "id": "cultivate_balanced",
        "text": "适度修炼，保持理智 (武力 +10, 悟性 +5)",
        "effects": [
          {"type": "stat_modify", "target": "martialPower", "value": 10, "operator": "add"},
          {"type": "stat_modify", "target": "comprehension", "value": 5, "operator": "add"}
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773317774544,
      "updatedAt": 1773717774544,
      "author": "development_team",
      "tags": ["幽影门", "修炼", "once"],
      "enabled": true
    }

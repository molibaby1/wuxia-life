            "condition": {
              "op": "and",
              "conditions": [
                { "op": "gte", "field": "money", "value": 50 },
                { "op": "not", "condition": { "op": "hasEvent", "field": "events", "value": "westJourney" } }
              ]
            },
            "weight": 12,
            "choices": [
              {
                "id": "journey_quick",
                "text": "快速往返（6 个月）",
                "timeSpan": { "value": 6, "unit": "month" },

[
  {
    "id": "career_path_choice",
    "version": "1.0.0",
    "category": "career",
    "priority": 1,
    "weight": 85,
    "ageRange": { "min": 20, "max": 35 },
    "triggers": [
      { "type": "age_reach", "value": 20 },
      { "type": "random", "value": 0.3 }
    ],
    "conditions": [
      { "type": "expression", "expression": "!flags.has(\"career_chosen\")" }
    ],
    "content": {
      "title": "人生抉择",
      "text": "站在人生的十字路口，你需要思考未来的发展方向。是入仕为官、经商致富，还是继续江湖闯荡？",
      "description": "选择你的职业发展路径"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "career_official",
        "text": "入仕为官（需求：学识≥60，魅力≥50，人脉≥40）",
        "conditions": [
          { "type": "expression", "expression": "knowledge >= 60 && charisma >= 50 && connections >= 40" }
        ],
        "effects": [
          {
            "type": "flag_set",
            "flag": "career_official_chosen"
          },
          {
            "type": "flag_set",
            "flag": "career_chosen"
          },
          {
            "type": "stat_modify",
            "target": "reputation",
            "value": 10,
            "operator": "add"
          },
          {
            "type": "event_record",
            "target": "career_official"
          }
        ]
      },
      {
        "id": "career_merchant",
        "text": "经商致富（需求：财富≥500，魅力≥40，人脉≥30）",
        "conditions": [
          { "type": "expression", "expression": "wealth >= 500 && charisma >= 40 && connections >= 30" }
        ],
        "effects": [
          {
            "type": "flag_set",
            "flag": "career_merchant_chosen"
          },
          {
            "type": "flag_set",
            "flag": "career_chosen"
          },
          {
            "type": "stat_modify",
            "target": "wealth",
            "value": 50,
            "operator": "add"
          },
          {
            "type": "event_record",
            "target": "career_merchant"
          }
        ]
      },
      {
        "id": "career_hermit",
        "text": "江湖隐士（需求：侠义≥60，学识≥40）",
        "conditions": [
          { "type": "expression", "expression": "chivalry >= 60 && knowledge >= 40" }
        ],
        "effects": [
          {
            "type": "flag_set",
            "flag": "career_hermit_chosen"
          },
          {
            "type": "flag_set",
            "flag": "career_chosen"
          },
          {
            "type": "stat_modify",
            "target": "chivalry",
            "value": 5,
            "operator": "add"
          },
          {
            "type": "event_record",
            "target": "career_hermit"
          }
        ]
      },
      {
        "id": "career_later",
        "text": "再考虑考虑",
        "effects": [
          {
            "type": "time_advance",
            "target": "age",
            "value": 1,
            "timeUnit": "year"
          },
          {
            "type": "event_record",
            "target": "career_later"
          }
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773461322000,
      "updatedAt": 1773461322000,
      "author": "development_team",
      "tags": ["职业", "选择", "发展"],
      "enabled": true
    }
  },

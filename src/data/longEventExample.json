                  { "op": "add", "field": "chivalry", "value": 10 },
                  { "op": "sub", "field": "money", "value": 30 },
                  { "op": "addEvent", "field": "events", "value": "westJourney" }
                ]
              },
              {
                "id": "journey_slow",
                "text": "慢慢游历（2 年）",
                "timeSpan": { "value": 2, "unit": "year" },
                "effects": [
                  { "op": "add", "field": "chivalry", "value": 30 },
                  { "op": "add", "field": "martialPower", "value": 15 },
                  { "op": "add", "field": "externalSkill", "value": 20 },
                  { "op": "sub", "field": "money", "value": 50 },
                  { "op": "addFlag", "field": "flags", "value": "wellTraveled" },
                  { "op": "addEvent", "field": "events", "value": "westJourney" }

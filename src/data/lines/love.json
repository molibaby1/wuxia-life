[
  {
    "id": "love_first_meet",
    "version": "1.0.0",
    "category": "side_quest",
    "priority": 0,
    "weight": 80,
    "ageRange": { "min": 15, "max": 35 },
    "triggers": [
      {"type": "age_reach", "value": 15},
      {"type": "random", "value": 0.6}
    ],
    "conditions": [
      {
        "type": "expression",
        "expression": "!flags.has(\"love_started\") && !flags.has(\"love_mature_started\") && !flags.has(\"love_elderly_started\") && !flags.has(\"hasLoveInterest\") && player.charisma >= 5"
      }
    ],
    "content": {
      "text": "市集中你与一名气质独特的青年/女子擦肩而过，对方回眸一笑，令人难忘。",
      "title": "初遇",
      "description": "缘起一瞬间。"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "love_greet",
        "text": "上前搭话，礼貌问候",
        "description": "你整理衣冠，以礼相待",
        "outcomes": [
          {
            "id": "great_success",
            "text": "对方被你温文尔雅的气质打动，主动与你多聊了几句。临别时，佳人轻声道：'公子/小姐若不嫌弃，明日此时，可否再会？'你心中暗喜，这或许是缘分的开始。",
            "condition": {"type": "expression", "expression": "charisma >= 10"},
            "effects": [
              {"type": "flag_set", "target": "love_started"},
              {"type": "flag_set", "target": "love_approach_method", "value": "polite_great"},
              {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mingyue", "name": "明月", "role": "lover", "delta": 25}},
              {"type": "stat_modify", "target": "charisma", "value": 3, "operator": "add"},
              {"type": "event_record", "target": "love_first_meet_greet_great"}
            ]
          },
          {
            "id": "success",
            "text": "对方微微一笑，与你简短交谈后离去。但那一颦一笑已深深刻在你心中。",
            "condition": {"type": "expression", "expression": "charisma >= 6"},
            "effects": [
              {"type": "flag_set", "target": "love_started"},
              {"type": "flag_set", "target": "love_approach_method", "value": "polite"},
              {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mingyue", "name": "明月", "role": "lover", "delta": 10}},
              {"type": "stat_modify", "target": "charisma", "value": 2, "operator": "add"},
              {"type": "event_record", "target": "love_first_meet_greet"}
            ]
          },
          {
            "id": "failure",
            "text": "你鼓起勇气上前搭话，却只换来对方礼貌而疏离的点头。对方匆匆离去，留下你一人站在原地，心中难免有些失落。",
            "condition": {"type": "expression", "expression": "true"},
            "effects": [
              {"type": "flag_set", "target": "love_started"},
              {"type": "flag_set", "target": "love_approach_method", "value": "polite_cold"},
              {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mingyue", "name": "明月", "role": "lover", "delta": 3}},
              {"type": "event_record", "target": "love_first_meet_greet_cold"}
            ]
          }
        ]
      },
      {
        "id": "love_charm",
        "text": "展示魅力，主动攀谈",
        "description": "你风流倜傥，展现风采",
        "outcomes": [
          {
            "id": "great_success",
            "text": "你的风采令对方眼前一亮！对方眼中闪过欣赏之色，与你相谈甚欢。临别时轻声道：'江湖路远，能遇公子/小姐这般有趣之人，实乃幸事。'你心中暗喜，这或许是命中注定的缘分。",
            "condition": {"type": "expression", "expression": "charisma >= 12"},
            "effects": [
              {"type": "flag_set", "target": "love_started"},
              {"type": "flag_set", "target": "love_approach_method", "value": "charming_great"},
              {"type": "flag_set", "target": "love_secret_met", "value": true},
              {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mingyue", "name": "明月", "role": "lover", "delta": 35}},
              {"type": "stat_modify", "target": "charisma", "value": 5, "operator": "add"},
              {"type": "event_record", "target": "love_first_meet_charm_great"}
            ]
          },
          {
            "id": "success",
            "text": "你风度翩翩的举止吸引了对方注意。短暂交谈后，对方眼中闪过一丝欣赏。",
            "condition": {"type": "expression", "expression": "charisma >= 7"},
            "effects": [
              {"type": "flag_set", "target": "love_started"},
              {"type": "flag_set", "target": "love_approach_method", "value": "charming"},
              {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mingyue", "name": "明月", "role": "lover", "delta": 15}},
              {"type": "stat_modify", "target": "charisma", "value": 3, "operator": "add"},
              {"type": "event_record", "target": "love_first_meet_charm"}
            ]
          },
          {
            "id": "failure",
            "text": "你试图展现魅力，却显得有些刻意。对方微微一笑，礼貌地结束了交谈。你心中暗叹：'或许她/他不是对的人...'",
            "condition": {"type": "expression", "expression": "true"},
            "effects": [
              {"type": "flag_set", "target": "love_started"},
              {"type": "flag_set", "target": "love_approach_method", "value": "charming_failed"},
              {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mingyue", "name": "明月", "role": "lover", "delta": 5}},
              {"type": "event_record", "target": "love_first_meet_charm_failed"}
            ]
          }
        ]
      },
      {
        "id": "love_pass",
        "text": "只是远远一望，默默离开",
        "description": "你选择远远观望",
        "effects": [
          {"type": "time_advance", "target": "age", "value": 10, "timeUnit": "day"},
          {"type": "event_record", "target": "love_first_meet_pass"}
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773317774544,
      "updatedAt": 1773317774544,
      "author": "development_team",
      "tags": ["爱情", "初遇", "支线", "once"],
      "enabled": true,
      "backgroundWeights": {
        "scholar": 0.8,
        "merchant": 0.9,
        "wuxia": 0.7,
        "frontier": 0.6
      }
    },
    "storyLine": "love_story",
    "cooldown": 0.5
  },

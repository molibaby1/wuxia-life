            ]
          }
        },
        {
          "node": {
            "id": "seek_manual_failed",
            "minAge": 16,
            "maxAge": 36,
            "text": "你找遍了东海之滨，也没有发现秘籍的踪迹。或许这只是一个传说吧。",
            "condition": {
              "op": "and",
              "conditions": [
                { "op": "hasEvent", "field": "events", "value": "seekManual" },
                { "op": "not", "condition": { "op": "hasFlag", "field": "flags", "value": "foundManual" } }
              ]
            },
            "autoNext": true,
            "weight": 100,
            "timeSpan": { "value": 1, "unit": "day" },
            "autoEffects": [
              { "op": "add", "field": "qinggong", "value": 5 }
            ]
          }
        }
      ]
    }
  ],

  "usage": {
    "description": "使用方法",
    "steps": [
      "1. 每个长事件包含多个 stages（阶段）",
      "2. 每个 stage 包含一个 node（剧情节点）",
      "3. 使用 condition 和 flag/event 来控制阶段之间的转换",
      "4. 使用 timeSpan 来控制每个阶段的时间跨度",
      "5. 第一阶段通常是触发阶段，提供选择",
      "6. 中间阶段是进展阶段，根据之前的选择有不同的剧情",
      "7. 最后阶段是结果阶段，给出最终奖励或惩罚"
    ],
    "timeUnits": {
      "day": "按日计算，适合短期事件（闭关、照顾病人、寻找物品）",
      "month": "按月计算，适合中期事件（师门任务、短途旅行）",
      "year": "按年计算，适合长期事件（长途游历、重大突破）"
    }
  }
}

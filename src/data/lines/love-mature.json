    ],
    "content": {
      "text": "与婉清相处日久，你们一起经历了许多江湖风雨，感情愈发深厚。她理解你的江湖路，支持你的选择。",
      "title": "相知相守",
      "description": "成熟的爱情不需要轰轰烈烈，只需相知相守。"
    },
    "eventType": "auto",
    "autoEffects": [
      {"type": "time_advance", "target": "age", "value": 3, "timeUnit": "month"},
      {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_mature", "name": "婉清", "role": "lover", "delta": 20}},
      {"type": "stat_modify", "target": "charisma", "value": 8, "operator": "add"},
      {"type": "stat_modify", "target": "chivalry", "value": 5, "operator": "add"},
      {"type": "flag_set", "target": "love_mature_bonded"},
      {"type": "event_record", "target": "love_mature_bonded"}
    ],
    "metadata": {
      "createdAt": 1773450500000,
      "updatedAt": 1773450500000,
      "author": "development_team",
      "tags": ["爱情", "成熟", "支线"],
      "enabled": true
    }
  },
  {

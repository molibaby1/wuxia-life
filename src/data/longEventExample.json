{
  "comment": "多阶段长事件示例 - 使用纯 JSON 数据描述",
  "description": "这个文件展示了如何用声明式数据结构定义多阶段长时间跨度的事件",
  
  "longEventExamples": [
    {
      "id": "closed_training_event",
      "name": "闭关修炼事件",
      "stages": [
        {
          "node": {
            "id": "closed_training_start",
            "minAge": 15,
            "maxAge": 50,
            "text": "你决定闭关修炼，突破当前瓶颈。",
            "condition": {
              "op": "and",
              "conditions": [
                { "op": "gte", "field": "martialPower", "value": 30 },
                { "op": "not", "condition": { "op": "hasEvent", "field": "events", "value": "closedTraining" } }
              ]
            },
            "weight": 15,
            "choices": [
              {
                "id": "train_10_days",
                "text": "闭关 10 天",
                "timeSpan": { "value": 10, "unit": "day" },
                "effects": [
                  { "op": "add", "field": "internalSkill", "value": 5 },
                  { "op": "addEvent", "field": "events", "value": "closedTraining" }
                ]
              },
              {
                "id": "train_30_days",
                "text": "闭关 30 天（一个月）",
                "timeSpan": { "value": 30, "unit": "day" },
                "effects": [
                  { "op": "add", "field": "internalSkill", "value": 12 },
                  { "op": "add", "field": "martialPower", "value": 8 },
                  { "op": "addEvent", "field": "events", "value": "closedTraining" }
                ]
              },
              {
                "id": "train_90_days",
                "text": "闭关 90 天（三个月）",
                "timeSpan": { "value": 90, "unit": "day" },
                "condition": {
                  "op": "gte", "field": "internalSkill", "value": 20
                },
                "effects": [
                  { "op": "add", "field": "internalSkill", "value": 30 },
                  { "op": "add", "field": "martialPower", "value": 20 },
                  { "op": "addFlag", "field": "flags", "value": "breakthrough" },
                  { "op": "addEvent", "field": "events", "value": "closedTraining" }
                ]
              }
            ]
          }
        },
        {
          "node": {
            "id": "closed_training_result",
            "minAge": 15,
            "maxAge": 51,
            "text": "经过长时间的闭关，你感觉体内真气澎湃，似乎突破在即！",
            "condition": {
              "op": "hasFlag",
              "field": "flags",
              "value": "breakthrough"
            },
            "autoNext": true,
            "weight": 100,
            "timeSpan": { "value": 1, "unit": "day" },
            "autoEffects": [
              { "op": "add", "field": "martialPower", "value": 15 },
              { "op": "add", "field": "internalSkill", "value": 20 },
              { "op": "clearFlags" }
            ]
          }
        }
      ]
    },

    {
      "id": "sect_mission_event",
      "name": "师门任务事件",
      "stages": [
        {
          "node": {
            "id": "sect_mission_start",
            "minAge": 14,
            "maxAge": 25,
            "text": "师傅叫住你：『徒儿，为师有个任务交给你。护送师妹去江南办事，你可愿意？』",
            "condition": {
              "op": "and",
              "conditions": [
                { "op": "ne", "field": "sect", "value": null },
                { "op": "not", "condition": { "op": "hasEvent", "field": "events", "value": "sectMission" } }
              ]
            },
            "weight": 20,
            "choices": [
              {
                "id": "accept_mission",
                "text": "接受任务",
                "timeSpan": { "value": 30, "unit": "day" },
                "effects": [
                  { "op": "add", "field": "chivalry", "value": 15 },
                  { "op": "add", "field": "money", "value": 50 },
                  { "op": "addFlag", "field": "flags", "value": "onMission" },
                  { "op": "addEvent", "field": "events", "value": "sectMission" }
                ]
              },
              {
                "id": "decline_mission",
                "text": "婉拒任务",
                "effects": [
                  { "op": "sub", "field": "chivalry", "value": 5 },
                  { "op": "addEvent", "field": "events", "value": "sectMission" }
                ]
              }
            ]
          }
        },
        {
          "node": {
            "id": "sect_mission_encounter",
            "minAge": 14,
            "maxAge": 26,
            "text": "护送途中，你们遇到了一群山贼拦路！",
            "condition": {
              "op": "hasFlag",
              "field": "flags",
              "value": "onMission"
            },
            "weight": 50,
            "choices": [
              {
                "id": "fight_bandits",
                "text": "出手迎敌",
                "timeSpan": { "value": 1, "unit": "day" },
                "condition": {
                  "op": "gte", "field": "martialPower", "value": 20
                },
                "effects": [
                  { "op": "add", "field": "chivalry", "value": 10 },
                  { "op": "add", "field": "martialPower", "value": 5 },
                  { "op": "addFlag", "field": "flags", "value": "missionSuccess" }
                ]
              },
              {
                "id": "bribe_bandits",
                "text": "用银子打发他们",
                "timeSpan": { "value": 1, "unit": "day" },
                "condition": {
                  "op": "gte", "field": "money", "value": 30
                },
                "effects": [
                  { "op": "sub", "field": "money", "value": 30 },
                  { "op": "addFlag", "field": "flags", "value": "missionSuccess" }
                ]
              },
              {
                "id": "flee_bandits",
                "text": "带着师妹逃跑",
                "timeSpan": { "value": 3, "unit": "day" },
                "condition": {
                  "op": "gte", "field": "qinggong", "value": 15
                },
                "effects": [
                  { "op": "add", "field": "qinggong", "value": 3 },
                  { "op": "addFlag", "field": "flags", "value": "missionPartial" }
                ]
              }
            ]
          }
        },
        {
          "node": {
            "id": "sect_mission_complete",
            "minAge": 14,
            "maxAge": 27,
            "text": "你们成功抵达江南，完成了任务！师傅对你的表现很满意。",
            "condition": {
              "op": "hasFlag",
              "field": "flags",
              "value": "missionSuccess"
            },
            "autoNext": true,
            "weight": 100,
            "timeSpan": { "value": 1, "unit": "day" },
            "autoEffects": [
              { "op": "add", "field": "chivalry", "value": 20 },
              { "op": "add", "field": "money", "value": 100 },
              { "op": "add", "field": "martialPower", "value": 10 },
              { "op": "clearFlags" }
            ]
          }
        },
        {
          "node": {
            "id": "sect_mission_partial",
            "minAge": 14,
            "maxAge": 27,
            "text": "虽然过程有些波折，但你们最终还是安全抵达了江南。",
            "condition": {
              "op": "hasFlag",
              "field": "flags",
              "value": "missionPartial"
            },
            "autoNext": true,
            "weight": 100,
            "timeSpan": { "value": 1, "unit": "day" },
            "autoEffects": [
              { "op": "add", "field": "chivalry", "value": 10 },
              { "op": "add", "field": "money", "value": 50 },
              { "op": "clearFlags" }
            ]
          }
        }
      ]
    },

    {
      "id": "long_journey_event",

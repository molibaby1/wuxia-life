    "version": "1.0.0",
    "category": "main_story",
    "priority": 1,
    "weight": 50,
    "ageRange": {
      "min": 21,
      "max": 30
    },
    "triggers": [
      {
        "type": "age_reach",
        "value": 21
      }
    ],
    "conditions": [
      {
        "type": "expression",
        "expression": "!flags.has(\"route_border\") && !flags.has(\"current_sect\") && !flags.has(\"sect_switch_cooldown\") && (player.qinggong >= 12 || player.comprehension >= 12) && !flags.has(\"route_beggars\") && !flags.has(\"route_buddhist\") && !flags.has(\"route_demonic\") && !flags.has(\"route_orthodox\") && !flags.has(\"route_official\") && !flags.has(\"sect_shaolin\") && !flags.has(\"sect_wudang\") && !flags.has(\"sect_emei\")"
      }
    ],
    "content": {
      "text": "边关商队在荒原上遭遇袭击，你出手相救。领队以异族礼节致谢，邀你随行。",
      "title": "边地奇缘",
      "description": "塞外风云初起。"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "border_join",
        "text": "随行边地",
        "description": "你决定前往边关投军",
        "outcomes": [
          {
            "id": "great_success",
            "text": "你武艺超群，在商队遭遇突袭时单枪匹马击退数倍敌人！领队惊叹道：\"真英雄也！\"边关守将亲自设宴款待，你被破格提拔为校尉，直接进入军官序列！",
            "condition": {"type": "expression", "expression": "martialPower >= 30 && constitution >= 20"},
            "effects": [
              {"type": "time_advance", "target": "age", "value": 15, "timeUnit": "day"},
              {"type": "flag_set", "target": "route_border"},
              {"type": "flag_set", "target": "current_sect", "value": "border"},
              {"type": "flag_set", "target": "border_trial_active"},
              {"type": "flag_set", "target": "border_rank", "value": "officer"},
              {"type": "stat_modify", "target": "martialPower", "value": 8, "operator": "add"},
              {"type": "stat_modify", "target": "reputation", "value": 10, "operator": "add"},
              {"type": "stat_modify", "target": "influence", "value": 5, "operator": "add"},
              {"type": "event_record", "target": "border_join_officer"}
            ]
          },
          {
            "id": "success",
            "text": "你身手不凡，随商队抵达边关后被守将看中，编入精锐部队。边关将士对你寄予厚望，你的军旅生涯就此开始。",
            "condition": {"type": "expression", "expression": "constitution >= 15 || martialPower >= 20"},
            "effects": [
              {"type": "time_advance", "target": "age", "value": 15, "timeUnit": "day"},
              {"type": "flag_set", "target": "route_border"},
              {"type": "flag_set", "target": "current_sect", "value": "border"},
              {"type": "flag_set", "target": "border_trial_active"},
              {"type": "flag_set", "target": "border_rank", "value": "soldier"},
              {"type": "stat_modify", "target": "martialPower", "value": 5, "operator": "add"},
              {"type": "stat_modify", "target": "constitution", "value": 3, "operator": "add"},
              {"type": "event_record", "target": "border_join_soldier"}
            ]
          },
          {
            "id": "partial",
            "text": "你随商队抵达边关，但守将见你体格一般，便将你编入辎重营。虽非一线作战，但边关生活也让你学会了坚强。",
            "condition": {"type": "expression", "expression": "true"},
            "effects": [
              {"type": "time_advance", "target": "age", "value": 15, "timeUnit": "day"},
              {"type": "flag_set", "target": "route_border"},
              {"type": "flag_set", "target": "current_sect", "value": "border"},
              {"type": "flag_set", "target": "border_trial_active"},
              {"type": "flag_set", "target": "border_rank", "value": "support"},
              {"type": "stat_modify", "target": "constitution", "value": 5, "operator": "add"},
              {"type": "stat_modify", "target": "businessAcumen", "value": 3, "operator": "add"},
              {"type": "event_record", "target": "border_join_support"}
            ]
          }
        ]
      },
      {
        "id": "border_decline",
        "text": "谢绝邀请",
        "description": "你决定不去边关",
        "effects": [
          {"type": "time_advance", "target": "age", "value": 10, "timeUnit": "day"},
          {"type": "stat_modify", "target": "comprehension", "value": 1, "operator": "add"},
          {"type": "event_record", "target": "border_encounter_decline"}
        ]
      }
    ],

[
  {
    "id": "outlaw_identity_beginning",
    "name": "加入幽影门",
    "description": "你决定加入幽影门，踏上与非传统门派结缘的武林之路。",
    "version": "1.0.0",
    "category": "identity",
    "priority": 95,
    "weight": 90,
    "ageRange": {"min": 15, "max": 25},
    "type": "identity",
    "eventType": "choice",
    "tags": ["outlaw", "identity", "early"],
    "triggers": [
      {"type": "age_reach", "value": 15}
    ],
    "triggerConditions": {
      "age": {"min": 15, "max": 25},
      "flags": {
        "not": ["outlaw_identity_done", "current_sect"]
      }
    },
    "conditions": [
      {"type": "expression", "expression": "!flags.has('outlaw_identity_done') && !flags.has('current_sect') && !flags.has('sect_switch_cooldown')"}
    ],
    "content": {
      "title": "幽影门之路",
      "text": "你厌倦了名门正派的虚伪，决定加入幽影门。幽影门使者看着你：'所谓正邪，不过是胜者书写的历史。加入我们，你将获得强大的力量，但也将与整个「正统」江湖为敌。你准备好了吗？记住：我们的道路虽不被认可，但我们有自己的底线——不杀无辜，不叛同道。'"
    },
    "choices": [
      {
        "id": "join_outlaw_full",
        "text": "毅然加入，发誓效忠",
        "description": "彻底拥抱幽影门的道路",
        "outcomes": [
          {
            "id": "great_success",
            "text": "使者眼中闪过一丝赞赏：\"好！老夫等这一天很久了！\"他传授你幽影门不传秘笈——【幽冥神功】！你的实力突飞猛进，正式成为幽影门核心弟子！",
            "condition": {"type": "expression", "expression": "martialPower >= 30 && chivalry <= -10"},
            "effects": [
              {"type": "flag_set", "target": "outlaw_identity_done"},
              {"type": "flag_set", "target": "sect_faction", "value": "unconventional"},
              {"type": "flag_set", "target": "current_sect", "value": "shadow_sect"},
              {"type": "flag_set", "target": "youming_core_disciple", "value": true},
              {"type": "stat_modify", "target": "martialPower", "value": 15, "operator": "add"},
              {"type": "stat_modify", "target": "internalSkill", "value": 8, "operator": "add"},
              {"type": "stat_modify", "target": "chivalry", "value": -8, "operator": "add"},
              {"type": "event_record", "target": "outlaw_join_core"}
            ]
          },
          {
            "id": "success",
            "text": "使者点点头：\"你有此决心，很好。\"他传授你幽影门入门功法，你正式成为幽影门弟子。从此与正道分道扬镳，江湖路远。",
            "condition": {"type": "expression", "expression": "martialPower >= 20"},
            "effects": [
              {"type": "flag_set", "target": "outlaw_identity_done"},
              {"type": "flag_set", "target": "sect_faction", "value": "unconventional"},
              {"type": "flag_set", "target": "current_sect", "value": "shadow_sect"},
              {"type": "stat_modify", "target": "martialPower", "value": 10, "operator": "add"},
              {"type": "stat_modify", "target": "chivalry", "value": -5, "operator": "add"},
              {"type": "event_record", "target": "outlaw_join_normal"}
            ]
          },
          {
            "id": "partial",
            "text": "使者上下打量你，沉吟片刻：\"根骨尚可，但心性未稳。先从外围做起吧。\"你成为幽影门的外围人员，需要证明自己的忠诚。",
            "condition": {"type": "expression", "expression": "true"},
            "effects": [
              {"type": "flag_set", "target": "outlaw_identity_done"},
              {"type": "flag_set", "target": "sect_faction", "value": "unconventional"},
              {"type": "flag_set", "target": "current_sect", "value": "shadow_sect"},
              {"type": "flag_set", "target": "youming外围", "value": true},
              {"type": "stat_modify", "target": "martialPower", "value": 5, "operator": "add"},
              {"type": "stat_modify", "target": "chivalry", "value": -3, "operator": "add"},
              {"type": "event_record", "target": "outlaw_join_peripheral"}
            ]
          }
        ]
      },
      {
        "id": "join_outlaw_conditional",
        "text": "加入但保留底线",
        "description": "成为幽影门弟子但保持自己的原则",
        "outcomes": [
          {
            "id": "success",
            "text": "使者微微一笑：\"保留底线？也好。我幽影门虽被视为邪道，但也自有规矩。\"你成为幽影门弟子，在正邪之间寻找自己的道路。",
            "condition": {"type": "expression", "expression": "chivalry >= 0"},
            "effects": [
              {"type": "flag_set", "target": "outlaw_identity_done"},
              {"type": "flag_set", "target": "sect_faction", "value": "unconventional"},
              {"type": "flag_set", "target": "current_sect", "value": "shadow_sect"},
              {"type": "flag_set", "target": "youming_principled", "value": true},
              {"type": "stat_modify", "target": "martialPower", "value": 5, "operator": "add"},
              {"type": "stat_modify", "target": "chivalry", "value": -2, "operator": "add"},
              {"type": "stat_modify", "target": "comprehension", "value": 3, "operator": "add"},
              {"type": "event_record", "target": "outlaw_join_principled"}
            ]
          },
          {
            "id": "failure",
            "text": "使者脸色一沉：\"我幽影门不收首鼠两端之人。你若不能全心投入，就请离开吧。\"你被婉拒于幽影门之外，但心中并无遗憾。",
            "condition": {"type": "expression", "expression": "true"},
            "effects": [
              {"type": "stat_modify", "target": "reputation", "value": -5, "operator": "add"},
              {"type": "event_record", "target": "outlaw_join_rejected"}
            ]
          }
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773317774544,
      "updatedAt": 1773717774544,
      "author": "development_team",
      "tags": ["幽影门", "身份", "早期", "once"],
      "enabled": true
    }
  },
  {
    "id": "outlaw_cultivation",

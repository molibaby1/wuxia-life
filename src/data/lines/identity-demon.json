      }
    },
    "conditions": [
      {"type": "expression", "expression": "flags.has('outlaw_identity_done')"}
    ],
    "content": {
      "title": "幽影门长老",
      "text": "你凭借过人的实力，成为幽影门长老，权倾一时。教中弟子见你都要行礼，江湖中人对你又恨又怕。但你心里清楚：所谓的「正」与「邪」，不过是胜利者的叙事。",
      "description": "成为幽影门权力核心"
    },
    "choices": [
      {
        "id": "lead_aggressive",
        "text": "带领幽影门走向更强 (武力 +20, 声望 +10)",
        "effects": [
          {"type": "stat_modify", "target": "martialPower", "value": 20, "operator": "add"},
          {"type": "stat_modify", "target": "reputation", "value": 10, "operator": "add"}
        ]
      },
      {
        "id": "lead_peacful",
        "text": "寻求与正派和平共处 (声望 +15, 人脉 +10)",
        "effects": [

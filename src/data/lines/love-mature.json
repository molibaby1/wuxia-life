          {"type": "event_record", "target": "love_affair_resist"}
        ]
      },
      {
        "id": "love_affair_yield",
        "text": "陷入情网，难以自拔",
        "effects": [
          {"type": "flag_set", "target": "love_affair"},
          {"type": "stat_modify", "target": "chivalry", "value": -20, "operator": "add"},
          {"type": "stat_modify", "target": "charisma", "value": 8, "operator": "add"},
          {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_current", "name": "现任", "role": "lover", "delta": -30}},
          {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_affair", "name": "情人", "role": "lover", "delta": 25}},
          {"type": "event_record", "target": "love_affair_yield"}
        ]
      },
      {
        "id": "love_affair_confess",
        "text": "向现任坦白",
        "effects": [
          {"type": "flag_set", "target": "love_affair_confessed"},
          {"type": "stat_modify", "target": "chivalry", "value": 5, "operator": "add"},
          {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_current", "name": "现任", "role": "lover", "delta": -15}},
          {"type": "event_record", "target": "love_affair_confess"}

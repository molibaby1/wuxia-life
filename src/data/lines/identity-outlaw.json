    "conditions": [
      {"type": "expression", "expression": "!flags.has('current_sect') && !flags.has('outlaw_identity_done') && !flags.has('route_demonic') && !flags.has('sect_switch_cooldown') && (chivalry <= 20 || flags.wandering == true)"}
    ],
    "content": {
      "title": "另一条路",
      "text": "你在江湖游历时，偶然接触到一些不受「正道联盟」认可的门派。这些门派不受江湖规矩约束，行事全凭己心。幽影门的使者找到你：「所谓正邪，不过是庙堂之人书写的历史。我们不求流芳百世，只求问心无愧。江湖传言我们残忍嗜杀，却不知我们收留的尽是被正派逼上绝路的孤儿遗孀。你，愿意加入我们吗？」",
      "description": "接触非传统门派"
    },
    "eventType": "choice",
    "choices": [
      {
        "text": "加入幽影门",
        "effects": [
          {"type": "flag_set", "flag": "sect_faction", "value": "unconventional"},
          {"type": "flag_set", "flag": "route_demonic"},
          {"type": "flag_set", "flag": "current_sect", "value": "shadow_sect"},
          {"type": "stat_modify", "stat": "martialPower", "value": 5},
          {"type": "stat_modify", "stat": "externalSkill", "value": 3}
        ]
      },
      {
        "text": "拒绝，保持独立",
        "effects": [
          {"type": "stat_modify", "stat": "chivalry", "value": 5},
          {"type": "flag_set", "flag": "sect_faction", "value": "neutral"}
        ]
      }
    ]
  },
  {

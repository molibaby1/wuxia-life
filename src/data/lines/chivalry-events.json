  {
    "id": "chivalry_high_hero_save",
    "version": "1.0",
    "category": "chivalry",
    "priority": 82,
    "weight": 60,
    "ageRange": {"min": 25, "max": 55},
    "triggers": [
      {"type": "age_reach", "value": 25},

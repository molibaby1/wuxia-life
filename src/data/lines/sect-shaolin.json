  {
    "id": "buddhist_secularize",
    "version": "1.0.0",
    "category": "special_event",
    "priority": 2,
    "weight": 15,
    "ageRange": { "min": 18, "max": 40 },
    "triggers": [{ "type": "age_reach", "value": 18 }],
    "conditions": [
      {
        "type": "expression",
        "expression": "flags.has(\"route_buddhist\") && !flags.has(\"buddhist_secularized\")"
      }
    ],
    "content": {
      "text": "你渐觉尘缘未了，向寺中请愿还俗。还俗后方可改换人生道路。",
      "title": "还俗抉择",
      "description": "佛门清净与红尘牵挂。"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "buddhist_leave",
        "text": "还俗下山",
        "effects": [
          { "type": "time_advance", "target": "age", "value": 1, "timeUnit": "month" },
          { "type": "flag_unset", "target": "route_buddhist" },
          { "type": "flag_set", "target": "buddhist_secularized" },
          { "type": "flag_unset", "target": "current_sect" },
          { "type": "flag_set", "target": "sect_switch_cooldown", "value": 3 },
          { "type": "stat_modify", "target": "reputation", "value": -15, "operator": "add" },
          { "type": "stat_modify", "target": "internalSkill", "value": -5, "operator": "add" },
          { "type": "event_record", "target": "buddhist_secularize_leave" }
        ]
      },
      {
        "id": "buddhist_stay",
        "text": "继续修行",
        "effects": [
          { "type": "time_advance", "target": "age", "value": 15, "timeUnit": "day" },
          { "type": "event_record", "target": "buddhist_secularize_stay" }
        ]
      }
    ],

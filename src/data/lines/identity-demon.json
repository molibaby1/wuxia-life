    "tags": ["outlaw", "identity", "final"],
    "triggers": [
      {"type": "age_reach", "value": 35}
    ],
    "triggerConditions": {
      "age": {"min": 35, "max": 55},
      "flags": {
        "required": ["outlaw_identity_done"]
      }
    },
    "conditions": [
      {"type": "expression", "expression": "flags.has('outlaw_identity_done')"}
    ],
    "content": {
      "title": "江湖终极决战",
      "text": "传统门派与非传统门派的战争即将爆发。作为幽影门高层，你必须做出选择。但你已经知道：所谓正邪，不过是胜者的叙事。这一次，你会如何选择？",
      "description": "决定幽影门的命运"
    },
    "choices": [
      {
        "id": "fight_to_end",
        "text": "战斗至最后 (武力检定)",
        "effects": [
          {"type": "stat_modify", "target": "martialPower", "value": 25, "operator": "add"}
        ]
      },
      {
        "id": "negotiate_peace",
        "text": "寻求和平解决方案",
        "effects": [
          {"type": "stat_modify", "target": "connections", "value": 20, "operator": "add"},
          {"type": "stat_modify", "target": "reputation", "value": 15, "operator": "add"}
        ]
      },
      {
        "id": "retire",
        "text": "退出江湖纷争",
        "effects": [
          {"type": "stat_modify", "target": "comprehension", "value": 10, "operator": "add"}
        ]
      }
    ],
    "metadata": {

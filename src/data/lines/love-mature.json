          {"type": "flag_set", "target": "love_started"},
          {"type": "flag_unset", "target": "love_ended"},
          {"type": "relation_change", "target": "lover", "operator": "add", "value": {"id": "lover_second", "name": "若兰", "role": "lover", "delta": 18}},
          {"type": "stat_modify", "target": "charisma", "value": 6, "operator": "add"},
          {"type": "stat_modify", "target": "constitution", "value": 5, "operator": "add"},
          {"type": "event_record", "target": "love_second_accept"}
        ]
      },
      {
        "id": "love_second_hesitate",
        "text": "犹豫不决",
        "effects": [
          {"type": "time_advance", "target": "age", "value": 2, "timeUnit": "month"},
          {"type": "stat_modify", "target": "chivalry", "value": -2, "operator": "add"},
          {"type": "event_record", "target": "love_second_hesitate"}
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773450500000,
      "updatedAt": 1773450500000,
      "author": "development_team",
      "tags": ["爱情", "再续", "支线"],

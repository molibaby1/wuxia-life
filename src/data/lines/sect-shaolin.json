[
  {
    "id": "buddhist_entry",
    "version": "1.0.0",
    "category": "main_story",
    "priority": 1,
    "weight": 35,
    "ageRange": { "min": 15, "max": 22 },
    "triggers": [{ "type": "age_reach", "value": 15 }],
    "conditions": [
      { "type": "expression", "expression": "!flags.has(\"route_buddhist\") && player.chivalry >= 10 && (flags.has(\"sect_shaolin\") || flags.has(\"shaolinDisciple\")) && !flags.has(\"route_beggars\") && !flags.has(\"route_border\") && !flags.has(\"route_demonic\") && !flags.has(\"route_orthodox\") && !flags.has(\"route_official\")" }
    ],
    "content": {
      "text": "寺中高僧与你谈经论道，愿引你入佛门修行。",
      "title": "佛门缘起",
      "description": "佛门一念，万事皆空。"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "buddhist_accept",
        "text": "入佛门修行",
        "description": "你跪拜佛前，剃度出家",
        "outcomes": [
          {
            "id": "great_success",
            "text": "你跪拜佛前时，天现异象——寺中长老惊叹：\"此子与佛有缘，悟性非凡！\"方丈亲自为你剃度，赐法号\"慧明\"，你直接成为方丈亲传弟子，日夜聆听佛法妙音。",
            "condition": {"type": "expression", "expression": "comprehension >= 18"},
            "effects": [
              {"type": "flag_set", "target": "route_buddhist"},
              {"type": "flag_set", "target": "buddhist_core_disciple", "value": true},
              {"type": "flag_set", "target": "buddhist_dharma_name", "value": "慧明"},
              {"type": "time_advance", "target": "age", "value": 1, "timeUnit": "month"},
              {"type": "stat_modify", "target": "internalSkill", "value": 8, "operator": "add"},
              {"type": "stat_modify", "target": "comprehension", "value": 5, "operator": "add"},
              {"type": "stat_modify", "target": "reputation", "value": 5, "operator": "add"},
              {"type": "event_record", "target": "buddhist_entry_accept_core"}
            ]
          },
          {
            "id": "success",
            "text": "你跪拜佛前，心诚感动寺中僧人。长老大僧为你剃度，赐你法号。你正式成为少林寺一名僧人，开始了修行生涯。",
            "condition": {"type": "expression", "expression": "comprehension >= 10"},
            "effects": [
              {"type": "flag_set", "target": "route_buddhist"},
              {"type": "flag_set", "target": "buddhist_dharma_name", "value": "慧能"},
              {"type": "time_advance", "target": "age", "value": 1, "timeUnit": "month"},
              {"type": "stat_modify", "target": "internalSkill", "value": 5, "operator": "add"},
              {"type": "stat_modify", "target": "comprehension", "value": 3, "operator": "add"},
              {"type": "event_record", "target": "buddhist_entry_accept"}
            ]
          },
          {
            "id": "failure",
            "text": "你跪拜佛前，心中却杂念四起。长老见你尘缘未断，叹道：\"你根骨尚可，但佛缘浅薄。先从杂役做起，磨练心性吧。\"你成为少林寺一名洒扫僧人。",
            "condition": {"type": "expression", "expression": "true"},
            "effects": [
              {"type": "flag_set", "target": "route_buddhist"},
              {"type": "flag_set", "target": "buddhist_menial_worker", "value": true},
              {"type": "time_advance", "target": "age", "value": 1, "timeUnit": "month"},
              {"type": "stat_modify", "target": "constitution", "value": 3, "operator": "add"},
              {"type": "stat_modify", "target": "internalSkill", "value": 2, "operator": "add"},
              {"type": "event_record", "target": "buddhist_entry_accept_menial"}
            ]
          }
        ]
      },
      {
        "id": "buddhist_decline",
        "text": "婉拒佛门",
        "description": "你决定不入佛门",
        "effects": [
          {"type": "time_advance", "target": "age", "value": 15, "timeUnit": "day"},
          {"type": "event_record", "target": "buddhist_entry_decline"}
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773317774544,
      "updatedAt": 1773317774544,
      "author": "development_team",
      "tags": ["佛门", "主线", "once"],
      "enabled": true
    }
  },
  {
    "id": "buddhist_love_trial",
    "version": "1.0.0",
    "category": "side_quest",
    "priority": 1,
    "weight": 22,
    "ageRange": { "min": 18, "max": 28 },
    "triggers": [{ "type": "age_reach", "value": 18 }],
    "conditions": [
      { "type": "expression", "expression": "flags.has(\"route_buddhist\") && flags.has(\"love_started\") && !flags.has(\"buddhist_love_trial\")" }
    ],
    "content": {
      "text": "寺中长老提醒你：情之一字，最易乱心。你该如何面对明月？",
      "title": "情劫",
      "description": "佛门与情缘的抉择。"
    },
    "eventType": "choice",
    "choices": [
      {
        "id": "buddhist_keep_love",
        "text": "情缘不舍",
        "effects": [
          { "type": "time_advance", "target": "age", "value": 20, "timeUnit": "day" },
          { "type": "relation_change", "target": "lover", "operator": "add", "value": { "id": "lover_mingyue", "name": "明月", "role": "lover", "delta": 4 } },
          { "type": "flag_set", "target": "buddhist_love_trial" },
          { "type": "event_record", "target": "buddhist_love_keep" }
        ]
      },
      {
        "id": "buddhist_release_love",
        "text": "斩断情缘",
        "effects": [
          { "type": "time_advance", "target": "age", "value": 1, "timeUnit": "month" },
          { "type": "stat_modify", "target": "chivalry", "value": 2, "operator": "add" },
          { "type": "flag_set", "target": "buddhist_love_trial" },
          { "type": "event_record", "target": "buddhist_love_release" }
        ]
      }
    ],
    "metadata": {
      "createdAt": 1773317774544,
      "updatedAt": 1773317774544,

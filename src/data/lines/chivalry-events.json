    ],
    "content": {
      "title": "英雄救美",
      "text": "路遇一女子被恶霸欺凌，围观者无人敢管。你义愤填膺，决定挺身而出。",
      "description": "英雄救美"
    },
    "eventType": "choice",
    "choices": [
      {
        "text": "挺身而出，教训恶霸",
        "description": "路见不平，拔刀相助",
        "conditions": [
          {"type": "expression", "expression": "martialPower >= 80"}
        ],
        "outcomes": [
          {
            "id": "great_success",
            "text": "你三招两式便将恶霸制服在地！恶霸抱头求饶，围观群众齐声叫好！被救女子盈盈下拜：\"多谢恩公救命之恩，小女子无以为报，唯有...\"她的眼中闪烁着感激与敬意。",
            "condition": {"type": "expression", "expression": "martialPower >= 90 && charisma >= 25"},
            "effects": [
              {"type": "stat_modify", "stat": "chivalry", "value": 25, "operator": "add"},
              {"type": "stat_modify", "stat": "reputation", "value": 35, "operator": "add"},
              {"type": "stat_modify", "stat": "martialPower", "value": 8, "operator": "add"},
              {"type": "stat_modify", "stat": "charisma", "value": 5, "operator": "add"},
              {"type": "flag_set", "flag": "hero_saved_girl", "value": true},
              {"type": "flag_set", "flag": "hero_romantic_encounter", "value": true},
              {"type": "event_record", "target": "hero_ rescue_great"}
            ]
          },
          {
            "id": "success",
            "text": "你出手教训恶霸，几个回合便将其打跑。围观群众拍手称快，被救女子感激不已：\"多谢英雄搭救！\"你挥挥手，转身离去，深藏功与名。",
            "condition": {"type": "expression", "expression": "martialPower >= 80"},
            "effects": [
              {"type": "stat_modify", "stat": "chivalry", "value": 20, "operator": "add"},
              {"type": "stat_modify", "stat": "reputation", "value": 25, "operator": "add"},
              {"type": "stat_modify", "stat": "martialPower", "value": 5, "operator": "add"},
              {"type": "flag_set", "flag": "hero_saved_girl", "value": true},
              {"type": "event_record", "target": "hero_rescue_normal"}
            ]
          },
          {
            "id": "partial",
            "text": "你与恶霸苦战一场，虽将其打跑，但也身负轻伤。女子感激你的仗义，帮你包扎伤口。此事虽不完美，但你的侠义之名更响亮了。",
            "condition": {"type": "expression", "expression": "true"},
            "effects": [
              {"type": "stat_modify", "stat": "chivalry", "value": 15, "operator": "add"},
              {"type": "stat_modify", "stat": "reputation", "value": 15, "operator": "add"},
              {"type": "stat_modify", "stat": "health", "value": -10, "operator": "add"},
              {"type": "flag_set", "flag": "hero_saved_girl", "value": true},
              {"type": "event_record", "target": "hero_rescue_injured"}
            ]
          }
        ]
      },
      {
        "text": "智取，报官处理",
        "description": "用计谋解决问题",
        "effects": [
          {"type": "stat_modify", "stat": "chivalry", "value": 12, "operator": "add"},
          {"type": "stat_modify", "stat": "reputation", "value": 10, "operator": "add"},
          {"type": "stat_modify", "stat": "influence", "value": 5, "operator": "add"},
          {"type": "event_record", "target": "hero_rescue_official"}
        ]
      }
    ]
  },
